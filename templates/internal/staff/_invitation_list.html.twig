{# Visual Key Recovery/Copy Assist if just generated #}
{% if app.flashes('invitation_link') is not empty %}
    {% for link in app.flashes('invitation_link') %}
        <div class="alert alert-info mt-3">
            <h3>Share Secure Invitation Link</h3>
            <p>Copy and share this pre-approved link with your new staff member. This link will expire in 48 hours.</p>
            <div class="input-group">
                <input type="text" readonly value="{{ link }}" class="form-control" id="shareable-link-input-{{ loop.index }}">
                <button class="btn btn-outline-secondary" onclick="navigator.clipboard.writeText('{{ link }}'); this.innerText='Copied!'; setTimeout(() => this.innerText='Copy Link', 2000); return false;">Copy Link</button>
            </div>
        </div>
    {% endfor %}
{% endif %}

{{ include('flash_messages.html.twig') }}

{# Pending / Active Invitations Table #}
<h3>Invitation Status</h3>
<p>Review the status of authorization tokens issued for your organization.</p>

<table class="table table-striped sortable">
    <thead>
    <tr>
        <th>Email Address</th>
        <th>Expires At</th>
        <th>Status</th>
        <th class="no-sort">Action</th>
    </tr>
    </thead>
    <tbody>
    {% for invite in invitations %}
        <tr>
            <td>{{ invite.email }}</td>
            <td>
                {% if not invite.used %}
                    {{ invite.expiresAt|date('M d, Y') }} /
                    {{ invite.expiresAt|date('h:i a') }}
                    <br />
                    ({{ invite.expiresAt|date('e') }})
                {% endif %}
            </td>
            <td>
                {% if invite.used %}
                    <span>Accepted</span>
                {% elseif invite.expiresAt < date() %}
                    <span>Expired</span>
                {% else %}
                    <span>Pending</span>
                {% endif %}
            </td>
            <td>
                {# Let the admin renew/resend the link if it is pending or expired (i.e. not yet used) #}
                {% if not invite.used %}
                    <button type="button" class="btn btn-sm btn-danger"
                            data-controller="sweetalert"
                            data-action="click->sweetalert#remove"
                            data-sweetalert-title-value="Revoke invitation?"
                            data-sweetalert-text-value="Are you sure you want to revoke access parameters for this token?"
                            data-sweetalert-confirm-button-text-value="Yes, revoke it!"
                            data-sweetalert-delete-url-value="{{ path('internal_staff_revoke', {'id': invite.id.toString()}) }}"
                            data-sweetalert-csrf-token-value="{{ csrf_token('revoke_invitation_' ~ invite.id.toString()) }}">
                        Revoke
                    </button>

                    <form action="{{ path('internal_staff_reinvite', {'id': invite.id.toString()}) }}" method="POST" style="display:inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('reinvite_invitation_' ~ invite.id.toString()) }}">
                        <button type="submit" class="btn btn-sm btn-info">Resend / Renew</button>
                    </form>
                {% endif %}
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="4">No invitation tokens currently registered for this tenant.</td>
        </tr>
    {% endfor %}
    </tbody>
</table>
