{% set currentUrl = path(app.request.attributes.get('_route'),
    app.request.attributes.get('_route_params')|merge(app.request.query.all)|merge({'ajax': 1})) %}

{% extends 'base.html.twig' %}

{% block title %}Manage Internal Staff{% endblock %}

{% block body %}
    <div class="container"
            {{ stimulus_controller('reload-content', { url: currentUrl }) }}
            data-action="modal-form:success->reload-content#refreshContent"
    >
        <div class="row flex-xl-nowrap">
            <div class="col-12 col-md-10 col-xl-8">
                <h1>Manage Internal Staff</h1>
            </div>
        </div>

        {{ include('internal/staff/_pending.html.twig') }}

        <hr>

        {{ include('internal/staff/_invitations.html.twig') }}
    </div>
{% endblock %}
