{{ include('flash_messages.html.twig') }}

{# Pending / Active Invitations Table #}
<p>Clients are created by sending a <a href="{{ path('internal_requests_list') }}">drop request</a>.</p>

<table class="table table-striped sortable">
    <thead>
    <tr>
        <th>Client</th>
        <th>Created By</th>
        <th>Created Date</th>
        <th>Document Count</th>
        <th class="no-sort">Action</th>
    </tr>
    </thead>
    <tbody>
    {% for client in clients %}
        <tr>
            <td>
                <div data-controller="inline-edit"
                     data-inline-edit-url-value="{{ path('internal_client_update_name', {'id': client.id.toString()}) }}"
                     data-inline-edit-field-value="clientName">
                    <span data-inline-edit-target="display">
                        <span data-inline-edit-target="output">{{ client.clientName }}</span>
                        <a href="#" data-action="click->inline-edit#toggle" class="ms-1"><span class="bi bi-pencil"></span></a>
                    </span>
                    <div data-inline-edit-target="form" class="d-none mt-2">
                        <textarea class="form-control mb-2" data-inline-edit-target="input">{{ client.clientName }}</textarea>
                        <button class="btn btn-sm btn-success" data-action="click->inline-edit#save">Save</button>
                        <button class="btn btn-sm btn-link" data-action="click->inline-edit#toggle">Cancel</button>
                    </div>
                </div>
            </td>
            <td>{{ client.createdBy?.name }}</td>
            <td>
                {{ client.createdAt|date('M d, Y h:i a') }}
            </td>
            <td>{{ client.documents|length }}</td>
            <td>
                {% if client.documents|length === 0 %}
                    <button type="button" class="btn btn-sm btn-danger"
                            data-controller="sweetalert"
                            data-action="click->sweetalert#remove"
                            data-sweetalert-title-value="Permanently delete client?"
                            data-sweetalert-text-value="Are you sure you want to delete this client?"
                            data-sweetalert-confirm-button-text-value="Yes, delete it!"
                            data-sweetalert-delete-url-value="{{ path('internal_client_delete', {'id': client.id.toString()}) }}"
                            data-sweetalert-csrf-token-value="{{ csrf_token('delete_client' ~ client.id.toString()) }}">
                        Permanently delete client
                    </button>
                {% endif %}
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="4">No clients currently registered for this tenant.</td>
        </tr>
    {% endfor %}
    </tbody>
</table>
