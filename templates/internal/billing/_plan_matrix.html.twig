{% if activePlanName is not defined %}
    {% set activePlanName = '' %}
{% endif %}

<section class="pricing-matrix">
    <div class="row gx-4 justify-content-center pt-1">

        {# Plan 1: Trial #}
        <article class="col-12 col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm hover-lift rounded-3 p-3 position-relative mt-3 {% if activePlanName == 'trial' %}border-success border-2 shadow{% else %}border{% endif %}" style="overflow: visible !important;">
                {% if activePlanName == 'trial' %}
                    <span class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-success px-3 py-2 fw-semibold">Current Plan</span>
                {% endif %}
                <div class="card-body d-flex flex-column mt-2">
                    <h3 class="h5 fw-bold text-dark mb-1">Free Trial</h3>
                    <p class="text-muted small mb-4" style="min-height: 48px;">Test drive our top-tier features with zero risk and no upfront commitments.</p>
                    <div class="d-flex align-items-baseline mb-4">
                        <span class="display-6 fw-bold text-dark">$0</span>
                        <span class="text-muted ms-2 small">for 14 days</span>
                    </div>
                    <ul class="list-unstyled mb-4 flex-grow-1">
                        <li class="d-flex align-items-start mb-2 small text-dark">
                            <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            <span>14-day fully-featured Pro trial</span>
                        </li>
                    </ul>
                    {% if activePlanName !== '' %}
                        <form action="{{ path('internal_billing_subscribe') }}" method="POST" data-turbo="false">
                            <input type="hidden" name="_token" value="{{ csrf_token('billing_subscribe') }}">
                            <input type="hidden" name="plan" value="trial">
                            <button type="submit" class="btn btn-outline-primary w-100 fw-semibold py-2" {% if activePlanName == 'trial' or tenant.stripeSubscriptionId %}disabled{% endif %}>
                                {% if activePlanName == 'trial' %}Active Plan{% else %}Start 14-Day Trial{% endif %}
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </article>

        {# Plan 2: Basic #}
        <article class="col-12 col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm hover-lift rounded-3 p-3 position-relative mt-3 {% if activePlanName == 'basic' %}border-success border-2 shadow{% else %}border{% endif %}" style="overflow: visible !important;">
                {% if activePlanName == 'basic' %}
                    <span class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-success px-3 py-2 fw-semibold">Current Plan</span>
                {% endif %}
                <div class="card-body d-flex flex-column mt-2">
                    <h3 class="h5 fw-bold text-dark mb-1">Basic Plan</h3>
                    <p class="text-muted small mb-4" style="min-height: 48px;">Essential document security for boutique clinics, independent practitioners, and sole attorneys.</p>
                    <div class="d-flex align-items-baseline mb-4">
                        <span class="display-6 fw-bold text-dark">$9</span>
                        <span class="text-muted ms-1 small">/month</span>
                    </div>
                    <ul class="list-unstyled mb-4 flex-grow-1">
                        <li class="d-flex align-items-start mb-2 small text-dark">
                            <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            <span>Secure Client Drop portal</span>
                        </li>
                        <li class="d-flex align-items-start mb-2 small text-dark">
                            <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            <span>Standard browser-side E2EE</span>
                        </li>
                        <li class="d-flex align-items-start mb-2 small text-dark">
                            <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            <span>Full Escrow Key Sync capability</span>
                        </li>
                        <li class="d-flex align-items-start mb-2 small text-dark">
                            <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            <span>Up to 3 active personnel slots</span>
                        </li>
                        <li class="d-flex align-items-start mb-2 small text-dark">
                            <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            <span>5 GB total storage limit</span>
                        </li>
                    </ul>
                    {% if activePlanName !== '' %}
                        <form action="{{ path('internal_billing_subscribe') }}" method="POST" data-turbo="false">
                            <input type="hidden" name="_token" value="{{ csrf_token('billing_subscribe') }}">
                            <input type="hidden" name="plan" value="basic">
                            <button type="submit" class="btn {% if activePlanName == 'basic' %}btn-secondary{% else %}btn-primary{% endif %} w-100 fw-semibold py-2" {% if activePlanName == 'basic' %}disabled{% endif %}>
                                {% if activePlanName == 'basic' %}Active Plan{% elseif tenant.stripeSubscriptionId %}Switch to Basic{% else %}Select Basic{% endif %}
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </article>

        {# Plan 3: Pro (Highlighted Card) #}
        <article class="col-12 col-md-6 col-lg-3">
            <div class="card h-100 shadow hover-lift rounded-3 p-3 position-relative mt-3 {% if activePlanName == 'pro' %}border-success border-2{% else %}premium-card-border{% endif %}" style="overflow: visible !important;">
                {% if activePlanName == 'pro' %}
                    <span class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-success px-3 py-2 fw-semibold">Current Plan</span>
                {% else %}
                    <span class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-primary px-3 py-2 fw-semibold">Recommended</span>
                {% endif %}
                <div class="card-body d-flex flex-column mt-2">
                    <h3 class="h5 fw-bold text-dark mb-1">Pro Plan</h3>
                    <p class="text-muted small mb-4" style="min-height: 48px;">Robust multi-user workspace management for growing firms.</p>
                    <div class="d-flex align-items-baseline mb-4">
                        <span class="display-6 fw-bold text-dark">$19</span>
                        <span class="text-muted ms-1 small">/month</span>
                    </div>
                    <ul class="list-unstyled mb-4 flex-grow-1">
                        <li class="d-flex align-items-start mb-2 small text-dark">
                            <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            <span>Everything in Basic Plan</span>
                        </li>
                        <li class="d-flex align-items-start mb-2 small text-dark">
                            <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            <span>Up to 15 active personnel slots</span>
                        </li>
                        <li class="d-flex align-items-start mb-2 small text-dark">
                            <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            <span>50 GB total storage limit</span>
                        </li>
                    </ul>
                    {% if activePlanName !== '' %}
                        <form action="{{ path('internal_billing_subscribe') }}" method="POST" data-turbo="false">
                            <input type="hidden" name="_token" value="{{ csrf_token('billing_subscribe') }}">
                            <input type="hidden" name="plan" value="pro">
                            <button type="submit" class="btn {% if activePlanName == 'pro' %}btn-secondary{% else %}btn-primary{% endif %} w-100 fw-semibold py-2 shadow-sm" {% if activePlanName == 'pro' %}disabled{% endif %}>
                                {% if activePlanName == 'pro' %}Active Plan{% elseif tenant.stripeSubscriptionId %}Switch to Pro{% else %}Select Pro{% endif %}
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </article>

        {# Plan 4: Enterprise #}
        <article class="col-12 col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm hover-lift rounded-3 p-3 position-relative mt-3 {% if activePlanName == 'enterprise' %}border-success border-2 shadow{% else %}border{% endif %}" style="overflow: visible !important;">
                {% if activePlanName == 'enterprise' %}
                    <span class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-success px-3 py-2 fw-semibold">Current Plan</span>
                {% endif %}
                <div class="card-body d-flex flex-column mt-2">
                    <h3 class="h5 fw-bold text-dark mb-1">Enterprise</h3>
                    <p class="text-muted small mb-4" style="min-height: 48px;">Unlimited personnel and no file storage limits.</p>
                    <div class="d-flex align-items-baseline mb-4">
                        <span class="display-6 fw-bold text-dark">$29</span>
                        <span class="text-muted ms-1 small">/month</span>
                    </div>
                    <ul class="list-unstyled mb-4 flex-grow-1">
                        <li class="d-flex align-items-start mb-2 small text-dark">
                            <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            <span>Everything in Pro Plan</span>
                        </li>
                        <li class="d-flex align-items-start mb-2 small text-dark">
                            <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            <span>Unlimited personnel slots</span>
                        </li>
                        <li class="d-flex align-items-start mb-2 small text-dark">
                            <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            <span>Unlimited E2EE storage capacity</span>
                        </li>
                        <li class="d-flex align-items-start mb-2 small text-dark">
                            <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            <span>Priority support queue response</span>
                        </li>
                    </ul>
                    {% if activePlanName !== '' %}
                        <form action="{{ path('internal_billing_subscribe') }}" method="POST" data-turbo="false">
                            <input type="hidden" name="_token" value="{{ csrf_token('billing_subscribe') }}">
                            <input type="hidden" name="plan" value="enterprise">
                            <button type="submit" class="btn {% if activePlanName == 'enterprise' %}btn-secondary{% else %}btn-primary{% endif %} w-100 fw-semibold py-2" {% if activePlanName == 'enterprise' %}disabled{% endif %}>
                                {% if activePlanName == 'enterprise' %}Active Plan{% elseif tenant.stripeSubscriptionId %}Switch to Enterprise{% else %}Select Enterprise{% endif %}
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </article>
    </div>
</section>
