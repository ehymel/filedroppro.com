{% extends 'base.html.twig' %}

{% block title %}Manage Subscription - Billing Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Small visual polish additions to augment standard Bootstrap */
        .premium-card-border {
            border: 2px solid var(--bs-primary) !important;
        }
        .pricing-feature-icon {
            width: 1.25rem;
            height: 1.25rem;
            flex-shrink: 0;
        }
        .hover-lift {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .hover-lift:hover {
            transform: translateY(-4px);
            box-shadow: var(--bs-box-shadow) !important;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="container py-5">

        {# Dashboard Header #}
        <header class="border-bottom pb-4 mb-5">
            <div class="row align-items-center">
                <div class="col-12 col-md-8">
                    <span class="badge text-uppercase bg-primary-subtle text-primary mb-2 px-3 py-2 fw-semibold tracking-wider">Workspace Management</span>
                    <h1 class="display-5 fw-bold text-dark mb-2">Workspace Subscription</h1>
                    <p class="lead text-muted mb-0">Configure your billing parameters, choose your service tier, and manage active organization subscriptions securely.</p>
                </div>
            </div>
        </header>

        {{ include('flash_messages.html.twig') }}

        {# Plan Status Box #}
        <section class="card shadow-sm border mb-5 rounded-3">
            <div class="card-body p-4 d-flex justify-content-between align-items-center flex-wrap gap-4">
                <div>
                    <h2 class="h5 fw-bold mb-1 text-dark">Current Status: {{ tenant.firmName }}</h2>
                    <p class="text-muted mb-0">
                        {% if tenant.stripeSubscriptionId %}
                            Your organization is currently registered under the <strong>{{ activePlanName|capitalize }}</strong> plan.
                        {% else %}
                            You have not registered an active paid plan. Access to vault document downloads may be restricted.
                        {% endif %}
                    </p>
                </div>
                <div>
                    {% if tenant.status == 'active' %}
                        <span class="badge rounded-pill bg-success-subtle text-success px-4 py-2 border border-success-subtle fw-semibold fs-7">Active / Paid</span>
                    {% elseif tenant.status == 'past_due' %}
                        <span class="badge rounded-pill bg-warning-subtle text-warning-emphasis px-4 py-2 border border-warning-subtle fw-semibold fs-7">Payment Failed (Retrying)</span>
                    {% else %}
                        <span class="badge rounded-pill bg-danger-subtle text-danger px-4 py-2 border border-danger-subtle fw-semibold fs-7">Suspended / Unpaid</span>
                    {% endif %}
                </div>
            </div>
        </section>

        {% if tenant.stripeSubscriptionId and tenant.stripeCustomerId %}

            {# STATE A: User is subscribed. Render direct Customer Billing Portal entry point #}
            <section class="card shadow-sm border rounded-3 mx-auto" style="max-width: 600px;">
                <div class="card-body p-4 text-center">
                    <h3 class="h5 fw-bold mb-2 text-dark">Manage Billing Parameters</h3>
                    <p class="text-muted mb-4 small">To update your credit card details, view billing invoices, download historical receipts, or safely modify your plan settings, click below to open Stripe's secure self-service portal.</p>
                    <form action="{{ path('internal_billing_portal') }}" method="POST" data-turbo="false">
                        <input type="hidden" name="_token" value="{{ csrf_token('billing_portal') }}">
                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-semibold shadow-sm">
                            Open Self-Service Portal
                        </button>
                    </form>
                </div>
            </section>

        {% else %}

            {# STATE B: No active subscription. Render full 4-tier pricing layout matrix #}
            <section class="pricing-matrix">
                <div class="row g-4 justify-content-center">

                    {# Plan 1: Trial #}
                    <article class="col-12 col-md-6 col-lg-3">
                        <div class="card h-100 shadow-sm hover-lift border rounded-3 p-3">
                            <div class="card-body d-flex flex-column">
                                <h3 class="h5 fw-bold text-dark mb-1">Free Trial</h3>
                                <p class="text-muted small mb-4" style="min-height: 48px;">Test drive our top-tier features with zero initial risk or upfront commitments.</p>
                                <div class="d-flex align-items-baseline mb-4">
                                    <span class="display-6 fw-bold text-dark">$0</span>
                                    <span class="text-muted ms-2 small">for 14 days</span>
                                </div>
                                <ul class="list-unstyled mb-4 flex-grow-1">
                                    <li class="d-flex align-items-start mb-2 small text-dark">
                                        <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                        <span>14-day fully-featured Pro trial</span>
                                    </li>
                                    <li class="d-flex align-items-start mb-2 small text-dark">
                                        <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                        <span>Browser-side E2EE drops</span>
                                    </li>
                                    <li class="d-flex align-items-start mb-2 small text-dark">
                                        <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                        <span>Up to 3 active personnel slots</span>
                                    </li>
                                </ul>
                                <form action="{{ path('internal_billing_subscribe') }}" method="POST" data-turbo="false">
                                    <input type="hidden" name="_token" value="{{ csrf_token('billing_subscribe') }}">
                                    <input type="hidden" name="plan" value="trial">
                                    <button type="submit" class="btn btn-outline-primary w-100 fw-semibold py-2">Start 14-Day Trial</button>
                                </form>
                            </div>
                        </div>
                    </article>

                    {# Plan 2: Basic #}
                    <article class="col-12 col-md-6 col-lg-3">
                        <div class="card h-100 shadow-sm hover-lift border rounded-3 p-3">
                            <div class="card-body d-flex flex-column">
                                <h3 class="h5 fw-bold text-dark mb-1">Basic Plan</h3>
                                <p class="text-muted small mb-4" style="min-height: 48px;">Essential document security for boutique clinics, independent practitioners, and sole attorneys.</p>
                                <div class="d-flex align-items-baseline mb-4">
                                    <span class="display-6 fw-bold text-dark">$19</span>
                                    <span class="text-muted ms-1 small">/month</span>
                                </div>
                                <ul class="list-unstyled mb-4 flex-grow-1">
                                    <li class="d-flex align-items-start mb-2 small text-dark">
                                        <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                        <span>Secure Client Drop portal</span>
                                    </li>
                                    <li class="d-flex align-items-start mb-2 small text-dark">
                                        <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                        <span>Standard browser-side E2EE</span>
                                    </li>
                                    <li class="d-flex align-items-start mb-2 small text-dark">
                                        <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                        <span>5 GB total storage limit</span>
                                    </li>
                                </ul>
                                <form action="{{ path('internal_billing_subscribe') }}" method="POST" data-turbo="false">
                                    <input type="hidden" name="_token" value="{{ csrf_token('billing_subscribe') }}">
                                    <input type="hidden" name="plan" value="basic">
                                    <button type="submit" class="btn btn-secondary w-100 fw-semibold py-2">Select Basic</button>
                                </form>
                            </div>
                        </div>
                    </article>

                    {# Plan 3: Pro (Highlighted Card) #}
                    <article class="col-12 col-md-6 col-lg-3">
                        <div class="card h-100 shadow hover-lift border premium-card-border rounded-3 p-3 position-relative">
                            <span class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-primary px-3 py-2 fw-semibold">Recommended</span>
                            <div class="card-body d-flex flex-column mt-2">
                                <h3 class="h5 fw-bold text-dark mb-1">Pro Plan</h3>
                                <p class="text-muted small mb-4" style="min-height: 48px;">Advanced security and robust multi-user workspace management parameters for growing firms.</p>
                                <div class="d-flex align-items-baseline mb-4">
                                    <span class="display-6 fw-bold text-dark">$49</span>
                                    <span class="text-muted ms-1 small">/month</span>
                                </div>
                                <ul class="list-unstyled mb-4 flex-grow-1">
                                    <li class="d-flex align-items-start mb-2 small text-dark">
                                        <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                        <span>Unlimited E2EE Client Drops</span>
                                    </li>
                                    <li class="d-flex align-items-start mb-2 small text-dark">
                                        <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                        <span>Full Escrow Key Sync capability</span>
                                    </li>
                                    <li class="d-flex align-items-start mb-2 small text-dark">
                                        <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                        <span>50 GB total storage limit</span>
                                    </li>
                                    <li class="d-flex align-items-start mb-2 small text-dark">
                                        <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                        <span>Priority support queue response</span>
                                    </li>
                                </ul>
                                <form action="{{ path('internal_billing_subscribe') }}" method="POST" data-turbo="false">
                                    <input type="hidden" name="_token" value="{{ csrf_token('billing_subscribe') }}">
                                    <input type="hidden" name="plan" value="pro">
                                    <button type="submit" class="btn btn-primary w-100 fw-semibold py-2 shadow-sm">Select Pro</button>
                                </form>
                            </div>
                        </div>
                    </article>

                    {# Plan 4: Enterprise #}
                    <article class="col-12 col-md-6 col-lg-3">
                        <div class="card h-100 shadow-sm hover-lift border rounded-3 p-3">
                            <div class="card-body d-flex flex-column">
                                <h3 class="h5 fw-bold text-dark mb-1">Enterprise</h3>
                                <p class="text-muted small mb-4" style="min-height: 48px;">Dedicated high-volume infrastructure with custom retention rules and administrative logs.</p>
                                <div class="d-flex align-items-baseline mb-4">
                                    <span class="display-6 fw-bold text-dark">$199</span>
                                    <span class="text-muted ms-1 small">/month</span>
                                </div>
                                <ul class="list-unstyled mb-4 flex-grow-1">
                                    <li class="d-flex align-items-start mb-2 small text-dark">
                                        <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                        <span>Everything in Pro Plan</span>
                                    </li>
                                    <li class="d-flex align-items-start mb-2 small text-dark">
                                        <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                        <span>Unlimited E2EE storage capacity</span>
                                    </li>
                                    <li class="d-flex align-items-start mb-2 small text-dark">
                                        <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                        <span>Private AWS S3 bucket option</span>
                                    </li>
                                    <li class="d-flex align-items-start mb-2 small text-dark">
                                        <svg class="pricing-feature-icon text-success me-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                        <span>Custom HIPAA & SOC 2 audit logs</span>
                                    </li>
                                </ul>
                                <form action="{{ path('internal_billing_subscribe') }}" method="POST" data-turbo="false">
                                    <input type="hidden" name="_token" value="{{ csrf_token('billing_subscribe') }}">
                                    <input type="hidden" name="plan" value="enterprise">
                                    <button type="submit" class="btn btn-secondary w-100 fw-semibold py-2">Select Enterprise</button>
                                </form>
                            </div>
                        </div>
                    </article>

                </div>
            </section>

        {% endif %}

    </div>
{% endblock %}
