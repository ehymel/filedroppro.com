{% extends 'base.html.twig' %}

{% block title %}Manage Subscription - Billing Dashboard{% endblock %}

{% block body %}
    <div class="container-fluid"  >
        <div class="row flex-xl-nowrap">
            <div class="col mb-2">
                <h1>Subscription Management</h1>
            </div>
        </div>

        {{ include('flash_messages.html.twig') }}

        <div class="row flex-xl-nowrap">
            <div class="col-xl-6 col-lg-8 col-md-10 col-12">
                <div class="billing-wrapper">

                    <section class="mb-4 border-1">
                        <div>
                            <span class="bold">Organization:</span>
                            <span>{{ tenant.firmName }}</span>
                        </div>
                        <div>
                            <span class="bold">Subscription Status:</span>
                            <span class="badge text-bg-{{ tenant.status === 'past-due' ? 'danger' : 'success' }}">
                                {{ tenant.status|capitalize }}
                            </span>
                        </div>
                        <div>
                            <span class="bold">Subscription Plan:</span>
                            <span>
                                {{ tenant.subscriptionPlan|capitalize }}
                                {% if tenant.subscriptionPlan === 'trial' %}
                                    {{- '(with '~leftDays~' days remaining in trial period.)' }}
                                {% endif %}
                            </span>
                        </div>
{#                                    {% if tenant.stripeSubscriptionId %}#}
{#                                        {{ tenant.subscriptionPlan|default('Standard SaaS Plan')|capitalize }}#}
{#                                    {% else %}#}
{#                                        No Subscription Registered#}
{#                                    {% endif %}#}
                    </section>

                    {% if tenant.stripeSubscriptionId and tenant.stripeCustomerId %}

                        {# STATE A: User is subscribed. Show Stripe Customer Self-Service Portal trigger #}
                        <section>
                            <div>
                                <div>
                                    <svg class="management-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="24" height="24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
                                    </svg>
                                </div>
                                <h3>Manage Billing Context</h3>
                                <p>
                                    Update your credit card on file, retrieve payment invoices, download historical receipts, or cancel your renewal plan via Stripe's official self-service interface.
                                </p>

                                <form action="{{ path('internal_billing_portal') }}" method="POST">
                                    <input type="hidden" name="_token" value="{{ csrf_token('billing_portal') }}">
                                    <button type="submit" class="btn btn-primary">
                                        Open Customer Billing Portal
                                        <svg class="btn-icon-right" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="16" height="16">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </section>

                    {% else %}

                        {# STATE B: No active subscription. Show promotional plan details and Checkout Session trigger #}
                        <section>
                            <div>
                                <h3>Subscribe to Professional Vault</h3>
                                <p>Unlock encrypted document drops, request pipelines, and secure storage archives for your organization.</p>
                            </div>

                            <div>
                                {# Plan Perks / Details #}
                                <div>
                                    <h4>Features Included</h4>

                                    <ul style="list-style: none; padding: 0;" class="ms-2">
                                        {% for feature in [
                                            'Browser-side E2EE Cryptographic Envelopes',
                                            'Secure Client Drop Portal (Unlimited External drops)',
                                            'Staff Invitation and Key Sync Pipeline',
                                            'Zero-knowledge direct file uploads to AWS S3',
                                            'Role-Based Access Controls & HIPAA audit-ready logs'
                                        ] %}
                                            <li>
                                                <svg class="check-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="18" height="18">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                                </svg>
                                                <span>{{ feature }}</span>
                                            </li>
                                        {% endfor %}
                                    </ul>
                                </div>

                                {# Checkout Call to Action #}
                                <div>
                                    <div>
                                        {{ include('main/_price_table.html.twig') }}
                                    </div>

                                    <form action="{{ path('internal_billing_subscribe') }}" method="POST">
                                        <input type="hidden" name="_token" value="{{ csrf_token('billing_subscribe') }}">
                                        <button type="submit" class="btn btn-primary">
                                            Subscribe with Credit Card
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </section>

                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
