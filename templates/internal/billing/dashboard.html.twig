{% extends 'base.html.twig' %}

{% block title %}Manage Subscription - Billing Dashboard{% endblock %}

{% block body %}
    <div class="container py-2">

        {# Dashboard Header #}
        <header class="border-bottom pb-4 mb-5">
            <div class="row align-items-center">
                <div class="col-12 col-md-8">
                    <h1 class="display-5 fw-bold text-dark mb-2">Workspace Subscription</h1>
                    <p class="lead text-muted mb-0">Configure your billing parameters, choose your service tier, and manage active organization subscriptions securely.</p>
                </div>
            </div>
        </header>

        {{ include('flash_messages.html.twig') }}

        {# Cancellation Pending Notice Banner #}
        {% if tenant.cancelAtPeriodEnd and tenant.currentPeriodEnd %}
            <div class="alert alert-warning border-warning-subtle d-flex align-items-center mb-4 p-4 rounded-3 shadow-sm" role="alert">
                <div class="me-3">
                    <span class="fs-3">📅</span>
                </div>
                <div>
                    <h4 class="alert-heading h6 fw-bold mb-1 text-warning-emphasis">Subscription Cancellation Pending</h4>
                    <p class="mb-0 text-muted small">Your subscription has been canceled but remains active for the remainder of your billing cycle. You will retain full access to E2EE downloads until <strong>{{ tenant.currentPeriodEnd|date('F j, Y') }}</strong>, after which your account will automatically be suspended.</p>
                </div>
            </div>
        {% endif %}

        {# Plan Status Box #}
        <section class="card shadow-sm border mb-5 rounded-3">
            <div class="card-body p-4 d-flex justify-content-between align-items-center flex-wrap gap-4">
                <div>
                    <h2 class="h5 fw-bold mb-1 text-dark">Current Status: {{ tenant.firmName }}</h2>
                    <p class="text-muted mb-0">
                        {% if tenant.subscriptionPlan == 'trial' %}
                            {% if tenant.currentPeriodEnd and tenant.currentPeriodEnd > date() %}
                                {% set remainingDays = tenant.currentPeriodEnd.diff(date()).days %}
                                Your organization is currently registered under a card-free <strong>Free Trial</strong>. You have <strong>{{ remainingDays }} days remaining</strong> (expires on {{ tenant.currentPeriodEnd|date('F j, Y') }}).
                            {% else %}
                                Your trial period has expired. Please select a premium plan below to restore vault access.
                            {% endif %}
                        {% elseif tenant.stripeSubscriptionId %}
                            Your organization is currently registered under the <strong>{{ activePlanName|capitalize }}</strong> plan.
                        {% else %}
                            You have not registered an active paid plan. Access to vault document downloads is currently restricted.
                        {% endif %}
                    </p>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div>
                        {% if tenant.status == 'active' %}
                            {% if tenant.subscriptionPlan == 'trial' %}
                                <span class="badge rounded-pill bg-info-subtle text-info px-4 py-2 border border-info-subtle fw-semibold fs-7">Active Free Trial</span>
                            {% elseif tenant.cancelAtPeriodEnd %}
                                <span class="badge rounded-pill bg-warning-subtle text-warning-emphasis px-4 py-2 border border-warning-subtle fw-semibold fs-7">Cancels Soon / Paid</span>
                            {% else %}
                                <span class="badge rounded-pill bg-success-subtle text-success px-4 py-2 border border-success-subtle fw-semibold fs-7">Active / Paid</span>
                            {% endif %}
                        {% elseif tenant.status == 'past_due' %}
                            <span class="badge rounded-pill bg-warning-subtle text-warning-emphasis px-4 py-2 border border-warning-subtle fw-semibold fs-7">Payment Failed (Retrying)</span>
                        {% else %}
                            <span class="badge rounded-pill bg-danger-subtle text-danger px-4 py-2 border border-danger-subtle fw-semibold fs-7">Suspended / Unpaid</span>
                        {% endif %}
                    </div>

                    {# Render portal manager shortcut strictly if they are an active Stripe customer #}
                    {% if tenant.stripeCustomerId and tenant.stripeSubscriptionId %}
                        <form action="{{ path('internal_billing_portal') }}" method="POST" data-turbo="false" class="m-0">
                            <input type="hidden" name="_token" value="{{ csrf_token('billing_portal') }}">
                            <button type="submit" class="btn btn-outline-secondary btn-sm fw-semibold">
                                Manage Payment Methods / Invoices
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </section>

        {# Render the Pricing matrix to all clients unconditionally to support easy self-service plan changes #}
        {{ include('internal/billing/_plan_matrix.html.twig') }}
    </div>
{% endblock %}
