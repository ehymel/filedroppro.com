{% set currentUrl = path(app.request.attributes.get('_route'),
    app.request.attributes.get('_route_params')|merge(app.request.query.all)|merge({'ajax': 1})) %}

{% extends 'base.html.twig' %}

{% block title %}Manage Document Requests - Internal Portal{% endblock %}

{% block body %}
    <div class="container"
            {{ stimulus_controller('reload-content', { url: currentUrl }) }}
            data-action="modal-form:success->reload-content#refreshContent"
    >
        <header class="border-bottom pb-4 mb-5">
            <div class="row align-items-center">
                <div class="col-12 col-md-8">
                    <h1 class="mb-2">Drop Request Management</h1>
                    <p class="lead text-muted mb-0">Generate secure drop links, track pending client uploads, and manage active requests.</p>
                </div>
            </div>
        </header>

        <div {{ stimulus_controller('modal-form', {hideFullPageOpenButton: true}) }}>
            {% if is_granted('CREATE_FILE_REQUEST') %}
            <button class="btn btn-primary fw-semibold py-2"
                    data-action="modal-form#open"
                    data-form-url="{{ path('internal_requests_new') }}"
                    data-modal-title="Invite External Client"
            >
                Invite External Clients to Upload Files
            </button>

            {{ include('_modal.html.twig', { modalTitle: 'Invite External Client' }) }}
            {% else %}
                <button type="button" class="btn btn-sm btn-primary" disabled style="opacity: 0.5; cursor: not-allowed;" title="Subscription inactive or past due">
                    Subscription Locked
                </button>
            {% endif %}
        </div>

        <div class="row flex-xl-nowrap mt-5">
            <main class="col ms-4" data-reload-content-target="content">
                {{ include('internal/drop_request/_list.html.twig') }}
            </main>
        </div>
    </div>
{% endblock %}
