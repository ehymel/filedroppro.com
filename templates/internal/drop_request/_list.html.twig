<h3>Active & Historical Requests</h3>
<p>Track the status of all secure document invitations sent from your firm.</p>

{{ include('flash_messages.html.twig') }}

{% set activeRequests = requests|filter(req => req.deletedAt === null) %}
{% set deletedRequests = requests|filter(req => req.deletedAt !== null) %}

{% if activeRequests|length > 0 %}
    <table class="table table-striped sortable">
    <thead>
    <tr>
        <th>Client</th>
        <th>Requested By</th>
        <th>Date Sent</th>
        <th>Status</th>
        <th class="no-sort">Actions</th>
    </tr>
    </thead>
    <tbody>
    {% for request in activeRequests %}
        <tr>
            <td>
                {{ request.clientName }}
                <br />
                (<small>{{ request.clientEmail }}</small>)
            </td>
            <td>
                {{ request.createdBy.name }}
                <br />
                (<small>{{ request.createdBy.email }}</small>)
            </td>
            <td>
                {{ request.createdAt|date('M d, Y') }}
                <br />
                {{ request.createdAt|date('g:i a') }}
            </td>
            <td>
                <span>{{ request.status|capitalize }}</span>
            </td>
            <td>
                {% if request.status == 'pending' %}
                    <form action="{{ path('internal_requests_resend', {'id': request.id.toString()}) }}" method="POST" style="display:inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('resend_request_' ~ request.id.toString()) }}">
                        <button type="submit" class="btn btn-sm btn-info">Resend Email</button>
                    </form>

                    <button type="button" class="btn btn-sm btn-danger"
                            data-controller="sweetalert"
                            data-action="click->sweetalert#remove"
                            data-sweetalert-title-value="Revoke this request?"
                            data-sweetalert-text-value="The client will no longer be able to use it."
                            data-sweetalert-confirm-button-text-value="Yes, revoke it!"
                            data-sweetalert-delete-url-value="{{ path('internal_requests_revoke', {'id': request.id.toString()}) }}"
                            data-sweetalert-csrf-token-value="{{ csrf_token('revoke_request_' ~ request.id.toString()) }}">
                        Revoke
                    </button>
                {% else %}
                    <button type="button" class="btn btn-sm btn-danger"
                            data-controller="sweetalert"
                            data-action="click->sweetalert#remove"
                            data-sweetalert-title-value="Hide this request?"
                            data-sweetalert-text-value="The request will be removed from this list. You will have the option to show it again later."
                            data-sweetalert-confirm-button-text-value="Yes, hide it!"
                            data-sweetalert-delete-url-value="{{ path('internal_requests_soft_delete', {'id': request.id.toString()}) }}"
                            data-sweetalert-csrf-token-value="{{ csrf_token('delete_request_' ~ request.id.toString()) }}">
                        Hide
                    </button>
                {% endif %}
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="5">
                No secure file requests have been generated yet.
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>
{% endif %}

{% if deletedRequests|length > 0 %}
<div data-controller="toggle-visibility">
    <label class="mt-1">
        Show Hidden Requests?
        <input type="checkbox" class="js-toggle-visibility-documents"
               data-action="change->toggle-visibility#toggle" />
    </label>

    <table class="table table-striped sortable d-none" data-toggle-visibility-target="element">
        <thead>
        <tr>
            <th>Client</th>
            <th>Requested Info</th>
            <th>Status</th>
            <th class="no-sort">Actions</th>
        </tr>
        </thead>
        <tbody>
        {% for request in deletedRequests %}
            <tr>
                <td>
                    <span class="strikethrough">
                        {{ request.clientName }}
                        <br />
                        (<small>{{ request.clientEmail }}</small>)
                    </span>
                </td>
                <td>
                    Request: {{ request.createdAt|date('M d, Y g:i a') }}
                        by {{ request.createdBy.name }} (<small>{{ request.createdBy.email }}</small>)
                    <br />
                    Hidden: {{ request.deletedAt|date('M d, Y g:i a') }}
                        by {{ request.deletedBy.name }} (<small>{{ request.deletedBy.email }}</small>)
                </td>
                <td>
                    <span>{{ request.status|capitalize }}</span>
                </td>
                <td>
                    <button type="button" class="btn btn-sm btn-danger"
                            data-controller="sweetalert"
                            data-action="click->sweetalert#remove"
                            data-sweetalert-title-value="Permanently delete this request?"
                            data-sweetalert-confirm-button-text-value="Yes, delete it!"
                            data-sweetalert-delete-url-value="{{ path('internal_requests_soft_delete', {'id': request.id.toString()}) }}"
                            data-sweetalert-csrf-token-value="{{ csrf_token('delete_request_' ~ request.id.toString()) }}">
                        Permanently Delete
                    </button>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">
                    No secure file requests have been generated yet.
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}
