{% set currentUrl = path(app.request.attributes.get('_route'),
    app.request.attributes.get('_route_params')|merge(app.request.query.all)) %}

{% extends 'base.html.twig' %}

{% block title %}Manage Internal Staff{% endblock %}

{% block body %}
    <div class="container"
            {{ stimulus_controller('reload-content', { url: currentUrl }) }}
            data-action="modal-form:success->reload-content#refreshContent"
    >
        {{ include('flash_messages.html.twig') }}

        <div class="row">
            <div class="col">
                <h1>Manage Internal Staff</h1>
                <p>Generate and manage secure single-use entry tokens for your <strong>internal</strong> staff.</p>
            </div>
        </div>

        <div {{ stimulus_controller('modal-form', {
            formUrl: path('internal_staff_list', { form: 1 }),
            hideFullPageOpenButton: true
        }) }}>
            <button class="btn btn-primary" data-action="modal-form#open">
                Invite Internal Staff Member
            </button>

            {{ include('_modal.html.twig', { modalTitle: 'Invite Internal Staff Member' }) }}
        </div>

        <div class="row mt-5">
            <div class="col-md-8 col-12" data-reload-content-target="content">
                {{ include('flash_messages.html.twig') }}
                {# Visual Key Recovery/Copy Assist if just generated #}
                {% if app.flashes('invitation_link') is not empty %}
                    {% for link in app.flashes('invitation_link') %}
                        <div class="mt-3">
                            <h3>Share Secure Invitation Link</h3>
                            <p>Copy and share this pre-approved link with your new staff member. This link will expire in 48 hours.</p>
                            <div>
                                <label for="shareable-link-input"></label>
                                <input type="text" readonly value="{{ link }}" id="shareable-link-input">
                                <button class="btn btn-sm btn-info ms-3" onclick="copyToClipboard(event)">Copy Link</button>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}

                {{ include('internal/_invitation_list.html.twig') }}
            </div>
        </div>
    </div>

    <script>
        function copyToClipboard(event) {
            const btn = event.currentTarget;
            const copyText = btn.previousElementSibling;
            if (copyText && copyText.id === "shareable-link-input") {
                copyText.select();
                copyText.setSelectionRange(0, 99999); // For mobile devices
                document.execCommand("copy");

                // Text feedback change
                const originalText = btn.textContent;
                btn.textContent = "Copied!";
                setTimeout(() => {
                    btn.textContent = originalText;
                }, 2000);
            }
        }
    </script>
{% endblock %}
