{% set currentUrl = path(app.request.attributes.get('_route'),
    app.request.attributes.get('_route_params')|merge(app.request.query.all)) %}

{% extends 'base.html.twig' %}

{% block title %}Manage Internal Staff{% endblock %}

{% block body %}
    <div class="container"
            {{ stimulus_controller('reload-content', { url: currentUrl }) }}
            data-action="modal-form:success->reload-content#refreshContent"
    >
        <div class="row">
            <div class="col">
                <h1>Manage Internal Staff</h1>
                <p>Generate and manage secure single-use entry tokens for your <strong>internal</strong> staff.</p>
            </div>
        </div>

        <div {{ stimulus_controller('modal-form', {hideFullPageOpenButton: true}) }}>
            <button class="btn btn-primary btn-sm"
                    data-action="modal-form#open"
                    data-form-url="{{ path('internal_staff_invite') }}"
                    data-modal-title="Invite Internal Staff Member"
            >
                Invite Internal Staff Member <span class="fa fa-plus-circle"></span>
            </button>

            {{ include('_modal.html.twig', { modalTitle: 'Invite Internal Staff Member' }) }}
        </div>

        <div class="row mt-5" data-reload-content-target="content">
            <div class="col-md-8 col-12">
                {# Visual Key Recovery/Copy Assist if just generated #}
                {% if app.flashes('invitation_link') is not empty %}
                    {% for link in app.flashes('invitation_link') %}
                        <div class="alert alert-info mt-3">
                            <h3>Share Secure Invitation Link</h3>
                            <p>Copy and share this pre-approved link with your new staff member. This link will expire in 48 hours.</p>
                            <div class="input-group">
                                <input type="text" readonly value="{{ link }}" class="form-control" id="shareable-link-input-{{ loop.index }}">
                                <button class="btn btn-outline-secondary" onclick="navigator.clipboard.writeText('{{ link }}'); this.innerText='Copied!'; setTimeout(() => this.innerText='Copy Link', 2000); return false;">Copy Link</button>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}

                {{ include('flash_messages.html.twig') }}

                {{ include('internal/_invitation_list.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
