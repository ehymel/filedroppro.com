{% extends 'base.html.twig' %}

{% block title %}Regenerate Cryptographic Identity - Secure Reset{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .password-reset-layout {
            max-width: 480px;
            margin: 5rem auto;
            padding: 2.5rem 2rem;
            background-color: #1e293b;
            border: 1px solid #334155;
            border-radius: 1rem;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3), 0 8px 10px -6px rgba(0, 0, 0, 0.3);
            font-family: system-ui, -apple-system, sans-serif;
            color: #f1f5f9;
        }
        .form-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        .form-header h1 {
            font-size: 1.75rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: #ffffff;
        }
        .form-header p {
            color: #94a3b8;
            font-size: 0.95rem;
            line-height: 1.5;
        }
        .form-group {
            margin-bottom: 1.5rem;
        }
        .form-group label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: #cbd5e1;
        }
        .form-input {
            width: 100%;
            padding: 0.75rem 1rem;
            background-color: rgba(15, 23, 42, 0.5);
            border: 1px solid #475569;
            border-radius: 0.5rem;
            color: #ffffff;
            font-size: 0.95rem;
            box-sizing: border-box;
            transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
        }
        .form-input:focus {
            outline: none;
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
        }
        .btn-submit {
            display: block;
            width: 100%;
            padding: 0.75rem 1rem;
            background-color: #4f46e5;
            border: none;
            border-radius: 0.5rem;
            color: #ffffff;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.15s ease-in-out;
        }
        .btn-submit:hover {
            background-color: #4338ca;
        }
        .btn-submit:disabled {
            background-color: #312e81;
            color: #94a3b8;
            cursor: not-allowed;
        }
        .warning-block {
            background-color: rgba(245, 158, 11, 0.1);
            border-left: 4px solid #f59e0b;
            padding: 1rem;
            border-radius: 0 0.5rem 0.5rem 0;
            font-size: 0.85rem;
            line-height: 1.5;
            color: #fef3c7;
            margin-bottom: 1.5rem;
        }
        .warning-block strong {
            color: #fbbf24;
            display: block;
            margin-bottom: 0.25rem;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="password-reset-layout">
        <div class="form-container">

            <header class="form-header">
                <h1>Set New Password</h1>
                <p>Generate a new cryptographic vault key and update your credentials for <strong>{{ userEmail }}</strong>.</p>
            </header>

            <div class="warning-block">
                <strong>E2EE Identity Warning:</strong>
                Because we operate a zero-knowledge, end-to-end encrypted platform, we do not store your private keys in plain text. Resetting a forgotten password forces your browser to generate a brand-new cryptographic keypair. You will temporarily lose access to old files until an administrator performs an escrow key-sync ceremony on your behalf.
            </div>

            {# Stimulus-Linked Password Reset Form Ceremony #}
            <div data-controller="password-reset"
                 data-is-admin="{{ isAdmin|default(false) ? '1' : '0' }}"
                 data-recovery-envelope="{{ recoveryWrappedPrivateKey|default('') }}"
                 data-escrow-envelopes="{{ escrowEnvelopes|default([])|json_encode|e('html_attr') }}">

                {# Local Javascript Process Alerters #}
                <div data-password-reset-target="statusIndicator" class="d-none" role="alert"></div>

                <form action="{{ path('user_password_reset', {'token': token}) }}"
                      method="POST"
                      data-action="submit->password-reset#executeCeremony"
                      data-password-reset-target="form">

                    <input type="hidden" name="_token" value="{{ csrf_token('reset_forgotten_password_token') }}">

                    <div class="form-group">
                        <label for="new-password">New Master Password</label>
                        <input type="password"
                               id="new-password"
                               name="new_password"
                               class="form-input"
                               required
                               autocomplete="new-password"
                               data-password-reset-target="newPasswordInput"
                               placeholder="••••••••">
                    </div>

                    <div class="form-group">
                        <label for="confirm-password">Confirm Password</label>
                        <input type="password"
                               id="confirm-password"
                               name="confirm_password"
                               class="form-input"
                               required
                               autocomplete="new-password"
                               data-password-reset-target="confirmPasswordInput"
                               placeholder="••••••••">
                    </div>

                    {% if isAdmin|default(false) %}
                        {# Admin-only: entering the one-time recovery code restores
                           access to the firm's documents. The code is used only in
                           the browser and is never submitted to the server. #}
                        <div class="form-group">
                            <label for="recovery-code">Recovery code <span style="font-weight:normal;">(optional — restores document access)</span></label>
                            <input type="text"
                                   id="recovery-code"
                                   class="form-input"
                                   autocomplete="off"
                                   data-password-reset-target="recoveryCodeInput"
                                   placeholder="XXXX-XXXX-XXXX-…">
                            <small>Enter the recovery code you saved when you created your firm to regain access to your encrypted documents. Leave blank if you don't have it.</small>
                        </div>
                    {% endif %}

                    <button type="submit" class="btn-submit" data-password-reset-target="submitButton">
                        Generate Keys & Reset Password
                    </button>
                </form>
            </div>

        </div>
    </div>
{% endblock %}
