{% extends 'base.html.twig' %}

{% block title %}Request Password Reset - Secure Vault{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .password-reset-layout {
            max-width: 480px;
            margin: 5rem auto;
            padding: 2.5rem 2rem;
            background-color: #1e293b;
            border: 1px solid #334155;
            border-radius: 1rem;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3), 0 8px 10px -6px rgba(0, 0, 0, 0.3);
            font-family: system-ui, -apple-system, sans-serif;
            color: #f1f5f9;
        }
        .form-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        .form-header h1 {
            font-size: 1.75rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: #ffffff;
        }
        .form-header p {
            color: #94a3b8;
            font-size: 0.95rem;
            line-height: 1.5;
        }
        .form-group {
            margin-bottom: 1.5rem;
        }
        .form-group label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: #cbd5e1;
        }
        .form-input {
            width: 100%;
            padding: 0.75rem 1rem;
            background-color: rgba(15, 23, 42, 0.5);
            border: 1px solid #475569;
            border-radius: 0.5rem;
            color: #ffffff;
            font-size: 0.95rem;
            box-sizing: border-box;
            transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
        }
        .form-input:focus {
            outline: none;
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
        }
        .btn-submit {
            display: block;
            width: 100%;
            padding: 0.75rem 1rem;
            background-color: #4f46e5;
            border: none;
            border-radius: 0.5rem;
            color: #ffffff;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.15s ease-in-out;
        }
        .btn-submit:hover {
            background-color: #4338ca;
        }
        .btn-link {
            display: block;
            text-align: center;
            margin-top: 1.5rem;
            color: #a5b4fc;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
        }
        .btn-link:hover {
            color: #c7d2fe;
            text-decoration: underline;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="password-reset-layout">
        <div class="form-container">

            <header class="form-header">
                <h1>Reset Password</h1>
                <p>Enter your email address below, and we will send you a secure link to reset your security credentials.</p>
            </header>

            {{ include('flash_messages.html.twig') }}

            <form action="{{ path('user_password_forgot') }}" method="POST">
                <input type="hidden" name="_token" value="{{ csrf_token('forgot_password_request') }}">

                <div class="form-group">
                    <label for="email-input">Email Address</label>
                    <input type="email"
                           id="email-input"
                           name="email"
                           class="form-input"
                           required
                           placeholder="you@firm.com"
                           autocomplete="email">
                </div>

                <button type="submit" class="btn-submit">
                    Send Secure Reset Link
                </button>

                <a href="{{ path('security_login') }}" class="btn-link">
                    Return to Login
                </a>
            </form>
        </div>
    </div>
{% endblock %}
