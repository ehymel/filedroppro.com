{% extends 'base.html.twig' %}

{% block title %}Request Password Reset - Secure Vault{% endblock %}

{% block body %}
    <div class="container">
        <div class="row flex-xl-nowrap">
            <div class="col-xl-6 col-lg-8 col-md-10 mx-auto">
                <h1>Reset Password</h1>
                <p>Enter your email address below, and we will send you a secure link to reset your security credentials.</p>
            </div>
        </div>
        <div class="row flex-xl-nowrap mt-5">
            <div class="col-xl-6 col-lg-8 col-md-10 mx-auto">
                {{ include('flash_messages.html.twig') }}

                <form action="{{ path('user_password_forgot') }}" method="POST">
                    <input type="hidden" name="_token" value="{{ csrf_token('forgot_password_request') }}">

                    <div class="form-floating">
                        <input type="email"
                               id="email"
                               name="email"
                               required="required"
                               placeholder="Email Address"
                               class="form-control mb-2"
                               autocomplete="email" />
                        <label for="email" class="form-label required">Email Address</label>

                        <button type="submit" class="btn btn-success">Send Secure Reset Link</button>
                        <a href="{{ path('security_login') }}" class="btn btn-link">
                            Return to Login
                        </a>
                    </div>

                </form>
            </div>
        </div>
    </div>
{% endblock %}
