{% extends 'base.html.twig' %}

{% block title %}Two-Factor Authentication{% endblock %}

{% block body %}
    <div class="container">
        <div class="row">
            <div class="login-form bg-light mt-4 p-4 col-xl-6 col-md-8 col-12">
                <h1 class="h3 mb-3 font-weight-normal">
                    Two-factor authentication:
                    <br />
                    Confirm your setup
                </h1>

                <p>
                    Open your Authenticator app and type the number from that app here.
                </p>

                {% for msg in app.flashes('danger') %}
                    <div class="alert alert-danger">
                        {{ msg }}
                    </div>
                {% endfor %}

                <form class="form" method="post">
                    <p class="widget">
                        <input
                                id="_auth_code"
                                type="text"
                                name="code"
                                autocomplete="one-time-code"
                                class="form-control"
                                autofocus
                                style="padding: 10px 5px; line-height: 28px; font-size: 24px; text-align: center;"
                                {#
                                https://www.twilio.com/blog/html-attributes-two-factor-authentication-autocomplete
                                If your 2fa methods are using numeric codes only, add these attributes for better user experience:
                                inputmode="numeric"
                                pattern="[0-9]*"
                                #}
                        />
                    </p>

                    {% if displayTrustedOption %}
                        <p class="widget">
                            <label for="_trusted">
                                <input id="_trusted" type="checkbox" name="{{ trustedParameterName }}" checked />
                                I'm on a trusted device. Remember me for one week.
                            </label>
                        </p>
                    {% endif %}
                    {% if isCsrfProtectionEnabled %}
                        <input type="hidden" name="{{ csrfParameterName }}" value="{{ csrf_token(csrfTokenId) }}">
                    {% endif %}
                    <a class="btn btn-link" href="{{ path('login_redirect') }}">Cancel</a>
                    <button class="btn btn-primary">Confirm</button>

                </form>

                <div class="mt-4">
                    <h1 class="h4">Having Trouble?</h1>

                    <p>
{#                        <a class="btn btn-link float-end" href="{{ path('2fa_qr_disable') }}">Remove 2FA from my account</a>#}

                        Try removing 2FA from your account (see link at right).
                        <br /><br />
                        You may also need to remove this site from your authentication app.
                    </p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
