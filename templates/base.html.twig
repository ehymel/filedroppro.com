<!DOCTYPE html>
<html lang="en" data-bs-theme="auto">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FileDrop Pro {% block title %}Welcome!{% endblock %}</title>
    <link rel="icon" type="image/x-icon" href="{{ asset('images/FDP_icon.ico') }}">

    {% block stylesheets %}
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}

    {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
    {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
    {% endif %}
</head>
<body {{ stimulus_controller('layout') }}>

<header class="sticky-top">
    <nav class="navbar navbar-expand-lg" aria-label="Main navigation">
        <div class="container-xl">
            <a class="navbar-brand d-flex align-items-center gap-2" href="{{ path('homepage')|default('#') }}">
{#                <i class="bi bi-box-arrow-in-down text-primary fs-4"></i>#}
                <img class="logo-icon me-1" alt="FDP logo" src="{{ asset('images/FDP_icon.png') }}">
                <span>FileDrop Pro</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            {% block header_navigation %}
                {% if is_granted('ROLE_USER') %}
                    {% set currentRoute = app.request.attributes.get('_route') %}
                    <div class="collapse navbar-collapse" id="mainNavbar">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-3">
                            <li class="nav-item">
                                <a class="nav-link{{ currentRoute matches '{^internal_documents*}' ? ' active bold'}}"
                                   href="{{ path('internal_documents_dashboard') }}">Documents</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link{{ currentRoute matches '{^internal_requests*}' ? ' active bold'}}"
                                   href="{{ path('internal_requests_list') }}">Client Drop Requests</a>
                            </li>
                            {% if is_granted('ROLE_ADMIN') %}
                                <li class="nav-item">
                                    <a class="nav-link{{ currentRoute matches '{^internal_staff*}' ? ' active bold'}}"
                                       href="{{ path('internal_staff_list') }}">Internal Staff</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link{{ currentRoute matches '{^internal_client*}' ? ' active bold'}}"
                                       href="{{ path('internal_client_list') }}">External Clients</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link{{ currentRoute matches '{^internal_billing*}' ? ' active bold'}}"
                                       href="{{ path('internal_billing_dashboard') }}">Billing</a>
                                </li>
                            {% endif %}
                            {% if is_granted('ROLE_SUPERUSER') %}
                                <li class="nav-item">
                                    <a class="nav-link{{ currentRoute matches '{^admin_tenant*}' ? ' active'}}"
                                       href="{{ path('admin_tenant_list') }}">Tenant Admin</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link{{ currentRoute matches '{^admin_user*}' ? ' active'}}"
                                       href="{{ path('admin_user_list') }}">Users</a>
                                </li>
                            {% endif %}
                        </ul>

                        <div class="d-flex align-items-center gap-3">
{#                            <a href="#" class="btn btn-sm btn-outline-secondary d-none d-lg-inline-block">Documentation</a>#}
                            <div class="dropdown">
                                <a class="nav-link dropdown-toggle" href="#"
                                   id="userDropdown" aria-haspopup="true" aria-expanded="false"
                                   data-bs-toggle="dropdown" role="button"
                                >
                                    <span class="bi bi-person-fill"></span> {{ app.user ? app.user.name|default }}
                                    <br />
                                    {% if app.user?.tenant %}
                                        <span class="bi bi-building-fill"></span> {{ app.user ? app.user.tenant?.firmName }}
                                        <br />
                                    {% endif %}
                                    {% if app.user?.email %}
                                        <span class="bi bi-envelope-fill"></span> {{ app.user.email|default }}
                                        <span class="caret"></span>
                                    {% endif %}
                                </a>
                                <div class="dropdown-menu" aria-labelledby="userDropdown">
                                    <a class="dropdown-item" href="{{ path('security_logout') }}" data-turbo-prefetch="false">Logout</a>
                                    <a class="dropdown-item" href="{{ path('2fa_manage') }}" data-turbo-prefetch="false">Manage 2fa</a>
                                    <a class="dropdown-item" href="{{ path('passkey_manage') }}" data-turbo-prefetch="false">Manage Passkeys</a>
                                    <a class="dropdown-item" href="{{ path('user_edit') }}">My Account</a>
                                </div>
                                {% if is_granted('IS_IMPERSONATOR') %}
                                    <a href="{{ impersonation_exit_path(path('homepage')) }}">Exit impersonation</a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endif %}
            {% endblock %}
        </div>
    </nav>
    <nav class="navbar navbar-status" aria-label="Subscription status">
        {% set plan = app.user.tenant?.subscriptionPlan %}
        <div class="container-xl">
            <p class="mt-1">
                <strong>Current Subscription Plan:</strong> {{ plan|capitalize }}
                {% if plan === 'trial' %}
                    {% set startDate = app.user.tenant.createdAt %}
                    {% set leftDays = 90 - date("now").diff(startDate).days %}
                    <span class="ms-3 badge rounded-pill {{ leftDays > 10 ? 'text-bg-info' : 'text-bg-danger' }}">Time remaining in trial: {{ leftDays}} days</span>
                {% else %}
                    <a href="{{ path('internal_billing_dashboard') }}" class="ms-3 btn btn-sm btn-outline-primary">Manage Subscription</a>
                {% endif %}
            </p>
        </div>
    </nav>
</header>

<main class="py-5">
    <div class="container-xl">
        {{ include('flash_messages.html.twig') }}

        {% block body %}{% endblock %}
    </div>
</main>

<footer class="footer py-4 mt-auto">
    <div class="container-xl">
        <div class="row align-items-center justify-content-between flex-column flex-sm-row gap-3">
            <div class="col-auto">
                <div class="d-flex align-items-center gap-2 text-muted small">
                    <span class="fw-semibold text-body">FileDrop Pro</span>
                    <span>&copy; {{ 'now'|date('Y') }}</span>
                </div>
            </div>
            <div class="col-auto">
                <ul class="nav list-unstyled d-flex gap-4 mb-0 small">
                    <li><a href="{{ path('terms') }}" class="link-secondary text-decoration-none">Terms</a></li>
                    <li><a href="{{ path('privacy') }}" class="link-secondary text-decoration-none">Privacy</a></li>
                    <li><a href="{{ path('support') }}" class="link-secondary text-decoration-none">Support</a></li>
                </ul>
            </div>
        </div>
    </div>
</footer>

</body>
</html>
