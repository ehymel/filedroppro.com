<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" type="image/x-icon" href="{{ asset('images/FDP_icon.ico') }}" />
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body data-turbo="false">
    {% block header %}
        <header class="flexheader">
            <div class="container-fluid">
                <div class="row mt-2 mb-2">
                    <div class="col-12 col-lg-4">
                        <span style="background-color: white;margin-right:5px;"><img class="logo-icon" alt="FDP logo" src="{{ asset('images/FDP_logo_100.png') }}"></span>
                    </div>
                    <div class="col-12 col-lg-2 me-auto">
                        <ul class="nav">
                            {% if is_granted('ROLE_USER') %}
                                <nav class="navbar-expand navbar-light">
                                    <ul class="navbar-nav ms-auto">
                                        <li class="nav-item dropdown">
                                            <a class="nav-link dropdown-toggle" href="#"
                                               id="userDropdown" aria-haspopup="true" aria-expanded="false"
                                               data-bs-toggle="dropdown" role="button"
                                            >
                                                <span class="fa fa-user"></span>
                                                {{ app.user ? app.user.name|default }}
                                                <span class="caret"></span>
                                            </a>
                                            <div class="dropdown-menu" aria-labelledby="userDropdown">
                                                <a class="dropdown-item" href="{{ path('security_logout') }}" data-turbo-prefetch="false">Logout</a>
                                                <a class="dropdown-item" href="{{ path('2fa_manage') }}" data-turbo-prefetch="false">Manage 2fa</a>
                                                <a class="dropdown-item" href="{{ path('passkey_manage') }}" data-turbo-prefetch="false">Manage Passkeys</a>
                                                <a class="dropdown-item" href="{{ path('user_edit') }}">My Account</a>
                                            </div>
                                            {% if is_granted('IS_IMPERSONATOR') %}
                                                <a href="{{ impersonation_exit_path(path('homepage')) }}">Exit impersonation</a>
                                            {% endif %}
                                        </li>
                                    </ul>
                                </nav>
                            {% endif %}
                        </ul>
                    </div>
                </div>
            </div>
        </header>
    {% endblock %}

    {% block navigation %}
        {% if is_granted('ROLE_USER') %}
            {% set currentRoute = app.request.attributes.get('_route') %}
            <nav class="navbar navbar-expand-lg navbar-light">
                <button class="navbar-toggler" type="button"
                        data-toggle="collapse" data-target="#navbarNavAltMarkup"
                >
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
                    <ul class="navbar-nav me-auto d-flex">

                    </ul>
                    <ul class="navbar-nav ms-auto">
                        {% if is_granted('ROLE_ADMIN') %}
                            <li class="nav-item{{ currentRoute matches '{^admin_(?![user|import])}' ? ' active bold'}}">
                                <a class="nav-link" href="{{ path('admin_home') }}">Site Admin</a>
                            </li>
                            <li class="nav-item{{ currentRoute matches '{^admin_user.*}' ? ' active bold'}}">
                                <a class="nav-link" href="{{ path('admin_user_list') }}">User Admin</a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </nav>
        {% endif %}
    {% endblock %}

    {{ include('admin/_breadcrumbs.html.twig') }}

    {{ include('flash_messages.html.twig') }}
    <div class="main-content">
        {% block body %}{% endblock %}
    </div>

    <div class="footer">
    <span class="footer-text">
        Oncology Support &copy; {{ "now"|date("Y") }}
        &nbsp;&nbsp;
        <a href="mailto:info@practicetally.com">info@oncologysupport.com</a>
    </span>
    </div>
    </body>
</html>
