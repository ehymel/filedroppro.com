{% extends 'base.html.twig' %}

{% block title %}Secure File Drop - {{ tenant.firmName }}{% endblock %}

{% block body %}
    <div class="container"
         id="drop-portal"
         data-controller="secure-drop"
         data-secure-drop-recipients-value="{{ recipientKeys|json_encode }}"
         data-secure-drop-tenant-public-key-value="{{ tenant.tenantPublicKey }}"
         data-secure-drop-presign-url-value="{{ path('drop_presign', {'joinCode': joinCode}) }}"
         data-secure-drop-finalize-url-value="{{ path('drop_finalize', {'joinCode': joinCode}) }}"
         data-secure-drop-rename-url-template-value="{{ path('drop_rename', {'documentId': 'DOCUMENT_ID'}) }}"
         data-secure-drop-delete-url-template-value="{{ path('drop_delete', {'documentId': 'DOCUMENT_ID'}) }}"
    >
        <header class="border-bottom pb-4 mb-3">
            <div class="row align-items-center">
                <div class="col-12 col-md-8">
                    <h1 class="mb-2">Document Request for {{ dropRequest.clientName }}</h1>
                    <div class="bg-success-subtle text-success-emphasis border-start border-success border-4 rounded-end p-3 mb-4">
                    <p><strong>From:</strong> {{ dropRequest.createdBy.firstName }} {{ dropRequest.createdBy.lastName }}
                        ({{ dropRequest.createdBy.email }}) at {{ dropRequest.tenant.firmName }}:</p>
                    {% if dropRequest is defined and dropRequest is not null %}
                        <strong>Instructions:</strong> {{ dropRequest.instructions }}
                    {% endif %}
                    </div>
                </div>
            </div>
        </header>

        <div class="row">
            <div class="col">
                {% include 'flash_messages.html.twig' %}

                <p class="lead">
                    Your files are encrypted before being uploaded.
                    No one, including our hosting providers, can read your documents.
                </p>

                {{ form_start(form, { 'attr': { 'data-action': 'submit->secure-drop#processUpload', 'data-secure-drop-target': 'form' } }) }}
                    {{ form_row(form.senderName, { 'attr': { 'data-secure-drop-target': 'senderName' } }) }}
                    {{ form_row(form.senderEmail, { 'attr': { 'data-secure-drop-target': 'senderEmail' } }) }}

                    <div id="upload-status-alert" class="d-none alert alert-danger" data-secure-drop-target="uploadStatusAlert" role="alert"></div>
                    <fieldset>
                        <legend>Select Files</legend>

                        {# Uppy Dashboard Mounting Container #}
                        <div id="uppy-dashboard-container" data-secure-drop-target="uppyContainer"></div>

                        {# Fallback native file input for legacy environments #}
                        <div id="legacy-file-fallback" style="display: none;">
                            <label for="file-input">Choose file to encrypt and send</label>
                            <input type="file" id="file-input" data-secure-drop-target="fileInput">
                            <p>Supported formats: PDF, DOCX, ZIP, JPG, PNG (Max 50MB)</p>
                        </div>
                    </fieldset>

                    <div id="progress-container" class="d-none alert alert-info" data-secure-drop-target="progressContainer">
                        <label id="progress-label">Status: Initializing Cryptographic Handshake...</label>
                        <progress max="100" value="0" data-secure-drop-target="progressBar"></progress>
                        <span id="progress-percentage" data-secure-drop-target="progressPercent">0%</span>
                    </div>

                    {% if dropRequest is defined and dropRequest is not null %}
                        <input type="hidden" data-secure-drop-target="reqToken" value="{{ dropRequest.token }}">
                    {% endif %}

                    <button type="submit" class="btn btn-primary ms-3 mt-2" data-secure-drop-target="submitBtn">
                        Click Here To Upload Files
                    </button>
                {{ form_end(form) }}
            </div>
            <div class="col-5">
                <div id="uploaded-files-container" class="mt-4 d-none" data-secure-drop-target="uploadedFilesContainer">
                    <h4>Files Uploaded in this Session</h4>
                    <p>Click on the file to edit the file name.</p>
                    <ul class="list-group" data-secure-drop-target="uploadedFilesList"></ul>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
