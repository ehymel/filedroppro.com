{% extends 'base.html.twig' %}

{% block title %}Secure File Drop - {{ tenant.firmName }}{% endblock %}

{% block body %}
    <div class="container"
         id="drop-portal"
         data-controller="secure-drop"
         data-secure-drop-recipients-value="{{ recipientKeys|json_encode }}"
         data-secure-drop-upload-url-value="{{ path('drop_upload', {'joinCode': joinCode}) }}"
         data-secure-drop-presign-url-value="{{ path('drop_presign', {'joinCode': joinCode}) }}"
         data-secure-drop-finalize-url-value="{{ path('drop_finalize', {'joinCode': joinCode}) }}"
    >
        <div class="row">
            <div class="col">
                <h1>Securely Send Files to {{ tenant.firmName }}</h1>
                <h3>End-to-End Encrypted Secure File Drop</h3>
                <p>Your files are encrypted locally in your browser before being transmitted. No one, including our hosting providers, can read your documents.</p>

                {# Personalized Instructions block for targeted file requests #}
                {% if dropRequest is defined and dropRequest is not null %}
                    <div data-secure-drop-target="instructionsContainer">
                        <h3>Document Request for {{ dropRequest.clientName }}</h3>
                        <p>Requested by: <strong>{{ dropRequest.createdBy.email }}</strong></p>
                        {% if dropRequest.instructions %}
                            <blockquote>
                                <p>"{{ dropRequest.instructions }}"</p>
                            </blockquote>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="row">
            <div class="col-5">
                {% include 'flash_messages.html.twig' %}

                {{ form_start(form, { 'attr': { 'data-action': 'submit->secure-drop#processUpload', 'data-secure-drop-target': 'form' } }) }}
                    {{ form_row(form.senderName, { 'attr': { 'data-secure-drop-target': 'senderName' } }) }}
                    {{ form_row(form.senderEmail, { 'attr': { 'data-secure-drop-target': 'senderEmail' } }) }}

                    <fieldset>
                        <legend>Select Files</legend>
                        <div>
                            <label for="file-input">Choose file to encrypt and send</label>
                            <input type="file" id="file-input" required data-secure-drop-target="fileInput">
                            <p>Supported formats: PDF, DOCX, XLSX, ZIP, JPG, PNG (Max 50MB)</p>
                        </div>
                    </fieldset>

                    <div id="progress-container" style="display:none;" data-secure-drop-target="progressContainer">
                        <label id="progress-label">Status: Initializing Cryptographic Handshake...</label>
                        <progress max="100" value="0" data-secure-drop-target="progressBar"></progress>
                        <span id="progress-percentage" data-secure-drop-target="progressPercent">0%</span>
                    </div>

                    {% if dropRequest is defined and dropRequest is not null %}
                        <input type="hidden" data-secure-drop-target="reqToken" value="{{ dropRequest.token }}">
                    {% endif %}

                    <button type="submit" class="btn btn-primary" data-secure-drop-target="submitBtn">
                        Encrypt & Upload Securely
                    </button>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
