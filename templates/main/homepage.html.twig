{% extends 'base.html.twig' %}

{% block body %}
<div class="container">
    <div class="row">
        <div class="col-auto">
            <img src="{{ asset('images/FDP_logo_250.png') }}" alt="logo">
        </div>
    </div>
    <div class="row">
        <div class="col-12 col-md-10 col-xl-8">
            The ultra-simple, HIPAA/SOC2-compliant document drop.
            <br />
            Send a secure, encrypted upload link to your clients in one click.
            <br />
            No portal account required for them to upload.
        </div>
    </div>
    <div class="row mt-4">
        <div class="col-12 col-md-10 col-xl-8">
            <h2>Features</h2>
            <ul class="larger">
                <li><span class="bold larger">Security:</span> FileDrop Pro features two-factor and passkey authentication,
                    and data encryption. All data is encrypted in transit and at rest.</li>

                <li><span class="bold larger">Availability:</span> FileDrop Pro is hosted on AWS with uptime monitoring, disaster recovery plans,
                    and regular backup.</li>

                <li><span class="bold larger">Confidentiality:</span> Is access to data strictly restricted to personnel that you specify. Since data
                    is stored in an encrypted state, it is not accessible by any other party.

                <li><span class="bold larger">Privacy:</span> No personal information is shared with third parties.</li>
            </ul>
        </div>
        <div class="col-12 col-md-2 col-xl-4 mt-2 border-1">
            <h3>What would you like to do?</h3>
            <ul class="larger">
                <li>Respond to a request to upload files</li>
                <li>Sign up for a free trial</li>
                <li>Log in to your account</li>
            </ul>
        </div>
    </div>
    <div class="row mt-4">
        <div class="col-8">
            <h2>Pricing</h2>
            <ul class="larger">
                <li><span class="bold larger">Free Trial:</span> Up to 100 files or 1 GB. No credit card required.</li>
                <li><span class="bold larger">Pro:</span> $29/month for up to 50 GB</li>
                <li><span class="bold larger">Enterprise:</span> $49/month for up to 500 GB</li>
            </ul>
        </div>
    </div>
    <div class="row mt-4">
        <div class="col-8">
            <h2>
                Try it for free
                <a href="{{ path('register') }}" class="btn btn-primary ms-4">Sign up</a>
            </h2>
        </div>
    </div>
</div>
{% endblock %}
