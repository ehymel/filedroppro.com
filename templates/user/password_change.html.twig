{% extends 'base.html.twig' %}

{% block body %}
    <div class="container">
        <div class="row">
            <div class="col-6">
                <h1>Change Password</h1>
                <p>Safely update your login and E2EE re-encryption parameters in browser memory.</p>

                {{ include('flash_messages.html.twig') }}

                {# Stimulus-Linked Form Ceremony Wrapper #}
                <div data-controller="password-update"
                     data-password-update-mode-value="change"
                     data-password-update-encrypted-private-key-value="{{ encryptedPrivateKey|escape('html_attr') }}">

                    {# Javascript Progress Status Alerts #}
                    <div data-password-update-target="statusIndicator" class="d-none" role="alert"></div>

                    <form action="{{ path('app_profile_change_password') }}"
                          method="POST"
                          data-action="submit->password-update#executeCeremony"
                          data-password-update-target="form">

                        <div class="form-floating mb-4">
                            <input type="password"
                                   id="current-password"
                                   name="current_password"
                                   class="form-control"
                                   required
                                   autocomplete="current-password"
                                   data-password-update-target="currentPasswordInput"
                                   placeholder="••••••••">
                            <label for="current-password required">Current Password</label>
                            <p class="small ms-2">Required to decrypt and safely transfer your private E2EE key envelope.</p>
                        </div>

                        <div class="form-floating mb-4">
                            <input type="password"
                                   id="new-password"
                                   name="new_password"
                                   class="form-control"
                                   required
                                   autocomplete="new-password"
                                   data-password-update-target="newPasswordInput"
                                   placeholder="••••••••">
                            <label for="new-password required">New Password</label>
                            <p  class="small ms-2">Must be at least 8 characters long.</p>
                        </div>

                        <div class="form-floating mb-4">
                            <input type="password"
                                   id="confirm-password"
                                   name="confirm_password"
                                   class="form-control mb-2"
                                   required
                                   autocomplete="new-password"
                                   data-password-update-target="confirmPasswordInput">
                            <label for="confirm-password">Confirm New Password</label>
                        </div>

                        <input type="hidden" name="_token" value="{{ csrf_token('change_password_ceremony') }}">

                        <div class="form-actions">
                            <button type="submit" class="btn btn-success ms-4" data-password-update-target="submitButton">
                                Re-encrypt & Update Password
                            </button>
                            <a href="{{ path('login_redirect') }}" class="btn btn-link">Cancel</a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
