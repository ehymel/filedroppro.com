{% extends 'base.html.twig' %}

{% block title %}Secure Registration - Document Portal{% endblock %}

{% block body %}
    <div class="container" id="registration-container"
         {{ stimulus_controller('registration') }}
         data-registration-has-invitation-value="{{ hasInvitation ? 'true' : 'false' }}">
        <div class="row">
            <div class="col-6">
                <h2 class="mt-6 text-center text-3xl font-extrabold tracking-tight">
                    Create your secure account
                </h2>
                <p class="mt-2 text-center text-sm text-slate-400">
                    Or
                    <a href="{{ path('security_login') }}" class="font-medium text-indigo-400 hover:text-indigo-300 transition duration-150 ease-in-out">
                        sign in to your existing account
                    </a>
                </p>
            </div>
        </div>

        <div class="row">
            <div class="col-6">
                {% include 'flash_messages.html.twig' %}

                {{ form_start(registrationForm, {
                    'attr': {
                        'id': 'registration-form',
                        'data-registration-target': 'form',
                        'data-action': 'submit->registration#handleSubmit'
                    }
                }) }}

                {# Scenario: User registering with a secure, locked invitation #}
                {% if hasInvitation %}
                    <p class="mt-1 larger">
                        You are registering as an authorized user of <strong>{{ tenantName }}</strong>.
                    </p>
                {% endif %}

                {{ form_row(registrationForm.email) }}
                {{ form_row(registrationForm.firstName) }}
                {{ form_row(registrationForm.lastName) }}
                {{ form_row(registrationForm.plainPassword.first, {
                    'attr': {'data-registration-target': 'passwordInput'}
                }) }}
                {{ form_row(registrationForm.plainPassword.second) }}

                {# Mode selection: Only visible if not registering via invite #}
                {% if not hasInvitation %}
                    <table class="table">
                        <tr>
                            <th colspan="2" class="text-center" style="background-color: #d0cfd5;">Registration Pathway</th>
                        </tr>
                        <tr>
                            {% for child in registrationForm.registrationMode %}
                                <td style="background-color: #f0eff5;">{{ form_row(child, {'attr': {'data-action': 'change->registration#toggleSections'} }) }}</td>
                            {% endfor %}
                        </tr>
                    </table>

                    {# Dynamic Section: Create New Tenant (firmName) #}
                    <div id="section-firm-name" data-registration-target="firmSection" class="d-none">
                        {{ form_row(registrationForm.firmName) }}
                    </div>

                    {# Dynamic Section: Join Existing Tenant (joinCode) #}
                    <div id="section-join-code" data-registration-target="joinSection" class="d-none">
                        {{ form_row(registrationForm.joinCode) }}
                    </div>
                {% endif %}

                {{ form_row(registrationForm.agreeTerms) }}

                <button type="submit" class="btn btn-primary m-4">
                    Register Account & Generate Keys
                </button>

                {{ form_end(registrationForm) }}
            </div>
        </div>

        {# One-time recovery code — shown once, client-side, before submit. Never sent to the server. #}
        <div data-registration-target="recoveryModal" class="d-none"
             style="position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:1080; display:flex; align-items:center; justify-content:center;">
            <div class="card shadow-lg" style="max-width:560px; width:92%;">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-2">Save your recovery code</h4>
                    <p class="text-muted">
                        This one-time recovery code is the <strong>only way</strong> to regain access to your
                        firm's encrypted documents if you ever forget your password. We cannot recover it for you.
                        Store it somewhere safe (a password manager) before continuing.
                    </p>
                    <div class="d-flex align-items-center gap-2 my-3">
                        <code data-registration-target="recoveryCodeOutput"
                              class="fs-5 fw-bold p-3 bg-light border rounded flex-grow-1 text-center"
                              style="letter-spacing:1px; word-break:break-all;"></code>
                        <button type="button" class="btn btn-outline-secondary"
                                data-action="click->registration#copyRecoveryCode">Copy</button>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="recovery-confirm"
                               data-registration-target="recoveryConfirm"
                               data-action="change->registration#toggleRecoveryConfirm">
                        <label class="form-check-label" for="recovery-confirm">
                            I have saved my recovery code in a safe place.
                        </label>
                    </div>
                    <button type="button" class="btn btn-primary w-100"
                            data-registration-target="recoveryContinue"
                            data-action="click->registration#confirmRecoverySave" disabled>
                        Continue & Create Account
                    </button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
