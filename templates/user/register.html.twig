{% extends 'base.html.twig' %}

{% block title %}Secure Registration - Document Portal{% endblock %}

{% block body %}
    <div id="registration-container"
         data-controller="registration"
         data-registration-has-invitation-value="{{ hasInvitation ? 'true' : 'false' }}"
         class="min-h-screen bg-slate-900 flex flex-col justify-center py-12 sm:px-6 lg:px-8 text-slate-100">
        <div class="sm:mx-auto w-full max-w-md">
            <!-- Logo / Icon -->
            <div class="flex justify-center">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-indigo-600 shadow-lg shadow-indigo-500/20">
                <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                </svg>
            </span>
            </div>
            <h2 class="mt-6 text-center text-3xl font-extrabold tracking-tight text-white">
                Create your secure account
            </h2>
            <p class="mt-2 text-center text-sm text-slate-400">
                Or
                <a href="{{ path('security_login') }}" class="font-medium text-indigo-400 hover:text-indigo-300 transition duration-150 ease-in-out">
                    sign in to your existing account
                </a>
            </p>
        </div>

        <div class="mt-8 sm:mx-auto w-full max-w-md">
            <div class="bg-slate-800 py-8 px-4 shadow-xl sm:rounded-2xl sm:px-10 border border-slate-700/50">

                {# Flash Messages #}
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="mb-4 rounded-lg p-4 text-sm {% if label == 'danger' %}bg-red-900/40 text-red-200 border border-red-800{% else %}bg-green-900/40 text-green-200 border border-green-800{% endif %}" role="alert">
                            {{ message }}
                        </div>
                    {% endfor %}
                {% endfor %}

                {{ form_start(registrationForm, {
                    'attr': {
                        'class': 'space-y-6',
                        'id': 'registration-form',
                        'data-registration-target': 'form',
                        'data-action': 'submit->registration#handleSubmit'
                    }
                }) }}

                {# Scenario: User registering with a secure, locked invitation #}
                {% if hasInvitation %}
                    <div class="rounded-lg bg-indigo-950/50 border border-indigo-800/60 p-4 mb-6">
                        <div class="flex">
                            <div class="flex-shrink-0">
                                <svg class="h-5 w-5 text-indigo-400" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
                                </svg>
                            </div>
                            <div class="ml-3">
                                <h3 class="text-sm font-medium text-indigo-200">Pre-Approved Invitation</h3>
                                <p class="mt-1 text-xs text-indigo-300">
                                    You are registering as an authorized user of <strong>{{ tenantName }}</strong>.
                                </p>
                            </div>
                        </div>
                    </div>
                {% endif %}

                {# Email field #}
                <div>
                    {{ form_label(registrationForm.email, 'Email address', {'label_attr': {'class': 'block text-sm font-medium text-slate-300'}}) }}
                    <div class="mt-1">
                        {{ form_widget(registrationForm.email, {
                            'attr': {
                                'class': 'appearance-none block w-full px-3 py-2 border border-slate-600 rounded-lg bg-slate-700/50 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm transition duration-150 ease-in-out disabled:opacity-50 disabled:cursor-not-allowed',
                                'autocomplete': 'email',
                                'placeholder': 'you@example.com'
                            }
                        }) }}
                    </div>
                    <div class="text-xs text-red-400 mt-1">
                        {{ form_errors(registrationForm.email) }}
                    </div>
                </div>

                {# Password field #}
                <div>
                    {{ form_label(registrationForm.plainPassword, 'Master Password', {'label_attr': {'class': 'block text-sm font-medium text-slate-300'}}) }}
                    <div class="mt-1">
                        {{ form_widget(registrationForm.plainPassword, {
                            'attr': {
                                'class': 'appearance-none block w-full px-3 py-2 border border-slate-600 rounded-lg bg-slate-700/50 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm transition duration-150 ease-in-out',
                                'autocomplete': 'new-password',
                                'placeholder': '••••••••',
                                'data-registration-target': 'passwordInput'
                            }
                        }) }}
                    </div>
                    <p class="mt-1 text-xs text-slate-400">
                        Must be a strong password. This master password derives your local encryption key.
                    </p>
                    <div class="text-xs text-red-400 mt-1">
                        {{ form_errors(registrationForm.plainPassword) }}
                    </div>
                </div>

                {# Mode selection: Only visible if not registering via invite #}
                {% if not hasInvitation %}
                    <div class="border-t border-slate-700/50 pt-4">
                        <label class="block text-sm font-medium text-slate-300 mb-2">Registration Pathway</label>
                        <div class="grid grid-cols-2 gap-4">
                            {% for child in registrationForm.registrationMode %}
                                <label class="relative flex flex-col p-4 rounded-lg border border-slate-600 bg-slate-700/20 hover:bg-slate-700/40 cursor-pointer select-none transition duration-150 ease-in-out focus-within:ring-2 focus-within:ring-indigo-500">
                                    <div class="flex items-center justify-between">
                                        <span class="text-sm font-semibold text-slate-200">{{ child.vars.label }}</span>
                                        {{ form_widget(child, {
                                            'attr': {
                                                'class': 'h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-slate-600 bg-slate-700',
                                                'data-action': 'change->registration#toggleSections'
                                            }
                                        }) }}
                                    </div>
                                    <span class="mt-1 text-xs text-slate-400">
                                        {% if child.vars.value == 'new' %}
                                            Register a new business tenant and database profile.
                                        {% else %}
                                            Request to join an existing organization.
                                        {% endif %}
                                    </span>
                                </label>
                            {% endfor %}
                        </div>
                        <div class="text-xs text-red-400 mt-1">
                            {{ form_errors(registrationForm.registrationMode) }}
                        </div>
                    </div>

                    {# Dynamic Section: Create New Tenant (firmName) #}
                    <div id="section-firm-name" data-registration-target="firmSection" class="hidden border-t border-slate-700/50 pt-4 space-y-6">
                        <div>
                            {{ form_label(registrationForm.firmName, 'Organization/Firm Name', {'label_attr': {'class': 'block text-sm font-medium text-slate-300'}}) }}
                            <div class="mt-1">
                                {{ form_widget(registrationForm.firmName, {
                                    'attr': {
                                        'class': 'appearance-none block w-full px-3 py-2 border border-slate-600 rounded-lg bg-slate-700/50 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm transition duration-150 ease-in-out',
                                        'placeholder': 'Apex Legal Partners'
                                    }
                                }) }}
                            </div>
                            <div class="text-xs text-red-400 mt-1">
                                {{ form_errors(registrationForm.firmName) }}
                            </div>
                        </div>
                    </div>

                    {# Dynamic Section: Join Existing Tenant (joinCode) #}
                    <div id="section-join-code" data-registration-target="joinSection" class="hidden border-t border-slate-700/50 pt-4 space-y-6">
                        <div>
                            {{ form_label(registrationForm.joinCode, 'Firm Security Join Code', {'label_attr': {'class': 'block text-sm font-medium text-slate-300'}}) }}
                            <div class="mt-1">
                                {{ form_widget(registrationForm.joinCode, {
                                    'attr': {
                                        'class': 'appearance-none block w-full px-3 py-2 border border-slate-600 rounded-lg bg-slate-700/50 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm tracking-wider uppercase transition duration-150 ease-in-out',
                                        'placeholder': 'TX-ABC123XYZ'
                                    }
                                }) }}
                            </div>
                            <p class="mt-1 text-xs text-slate-400">
                                Ask your organization administrator for their unique secure join code.
                            </p>
                            <div class="text-xs text-red-400 mt-1">
                                {{ form_errors(registrationForm.joinCode) }}
                            </div>
                        </div>
                    </div>
                {% endif %}

                {# Consent / Agreement #}
                <div class="flex items-start border-t border-slate-700/50 pt-4">
                    <div class="flex items-center h-5">
                        {{ form_widget(registrationForm.agreeTerms, {
                            'attr': {
                                'class': 'focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-slate-600 bg-slate-700 rounded'
                            }
                        }) }}
                    </div>
                    <div class="ml-3 text-sm">
                        {{ form_label(registrationForm.agreeTerms, 'I acknowledge the E2EE encryption policies and agree to keep my master password secure.', {'label_attr': {'class': 'font-medium text-slate-300'}}) }}
                        <div class="text-xs text-red-400 mt-1">
                            {{ form_errors(registrationForm.agreeTerms) }}
                        </div>
                    </div>
                </div>

                {# Submit Button #}
                <div>
                    <button type="submit" class="w-full flex justify-center py-2.5 px-4 border border-transparent rounded-lg shadow-sm text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition duration-150 ease-in-out">
                        Register Account & Generate Keys
                    </button>
                </div>

                {{ form_end(registrationForm) }}
            </div>
        </div>
    </div>
{% endblock %}
