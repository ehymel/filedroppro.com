{% extends 'base.html.twig' %}

{% block body %}
    <div class="container">
        <div class="row">
            <div class="col-6">
                <h1>Reset Forgotten Password</h1>
                <p>Generate a brand-new cryptographic identity and update your system credentials.</p>

                {{ include('flash_messages.html.twig') }}

                {# Stimulus-Linked Forgot Reset Wrapper #}
                <div data-controller="password-update"
                     data-password-update-mode-value="reset">

                    <div class="warning-callout">
                        <strong>Attention:</strong> Because you are resetting a forgotten password, your existing E2EE private key cannot be decrypted. Resetting will generate a brand-new public identity key. Staff members will temporarily lose access to historical vault documents until approved by an administrator.
                    </div>

                    {# Javascript Progress Status Alerts #}
                    <div data-password-update-target="statusIndicator" class="status-alert" style="display:none;" role="alert"></div>

                    <form action="{{ path('app_reset_password', {'token': token, 'email': userEmail}) }}"
                          method="POST"
                          data-action="submit->password-update#executeCeremony"
                          data-password-update-target="form">

                        <input type="hidden" name="_token" value="{{ csrf_token('reset_forgotten_password') }}">

                        <div class="form-group">
                            <label for="new-password">Choose New Password</label>
                            <input type="password"
                                   id="new-password"
                                   name="new_password"
                                   required
                                   autocomplete="new-password"
                                   data-password-update-target="newPasswordInput"
                                   placeholder="••••••••">
                            <p class="field-hint">Must be at least 8 characters long.</p>
                        </div>

                        <div class="form-group">
                            <label for="confirm-password">Confirm New Password</label>
                            <input type="password"
                                   id="confirm-password"
                                   name="confirm_password"
                                   required
                                   autocomplete="new-password"
                                   data-password-update-target="confirmPasswordInput"
                                   placeholder="••••••••">
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn btn-submit" data-password-update-target="submitButton">
                                Regenerate Cryptographic Identity & Reset
                            </button>
                            <a href="{{ path('security_login') }}" class="btn btn-link">Return to Login</a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
