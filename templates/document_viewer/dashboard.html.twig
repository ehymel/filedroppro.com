{% extends 'base.html.twig' %}

{% block title %}Document Vault - Internal Dashboard{% endblock %}

{% block body %}
    <div class="container" id="vault-dashboard"
         data-controller="document-viewer"
         data-document-viewer-encrypted-private-key-value="{{ encryptedPrivateKey }}"
    >
        <div class="row">
            <div class="col">
                <span>Internal Secure Vault</span>
                <h1>Document Management</h1>
                <p>Access and unseal end-to-end encrypted items submitted by external clients.</p>
            </div>
        </div>

        <div class="row mb-5">
            <div class="col">
                {# Session Authentication Interceptor Modals #}
                <div class="modal fade" id="crypto-session-modal" tabindex="-1" aria-labelledby="cryptoModalLabel" aria-hidden="true" data-document-viewer-target="cryptoModal">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="cryptoModalLabel">Unlock Security Workspace</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <p>Your password is required to unlock files during this session.</p>
                                <div class="form-floating mb-3">
                                    <input type="password" id="vault-session-password" class="form-control"
                                           placeholder="Password"
                                           data-document-viewer-target="masterPasswordInput"
                                    >
                                    <label for="vault-session-password">Password</label>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="button"
                                        class="btn btn-primary"
                                        data-action="click->document-viewer#initializeCryptoSession"
                                >
                                    Unlock Workspace Memory
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {% for client in clients %}
        <div class="row mb-5">
            <div class="col-md-9 col-12">
                <h2>Documents uploaded from <span style="text-decoration: underline">{{ client.clientName }}</span></h2>
                <p>Client records and encrypted transfers linked to this profile.</p>

                <table class="table table-striped sortable">
                    <thead>
                    <tr>
                        <th>File Reference Path</th>
                        <th>Uploaded date</th>
                        <th class="no-sort">Status</th>
                        <th class="no-sort">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for doc in client.documents %}
                        <tr>
                            <td>
                                <span class="bold">{{ doc.filePath }}</span>
                                <div data-controller="document-note"
                                     data-document-note-url-value="{{ path('internal_documents_update_note', {'id': doc.id.toString()}) }}">
                                    <div data-document-note-target="display" class="mb-1">
                                        <span style="text-decoration: underline">Note:</span> {{ doc.note|default('No note added.') }}
                                        <a href="#" data-action="click->document-note#toggle"><span class="fa fa-edit"></span></a>
                                    </div>
                                    <div data-document-note-target="form" class="d-none mt-2">
                                        <textarea class="form-control mb-2" data-document-note-target="input">{{ doc.note }}</textarea>
                                        <button class="btn btn-sm btn-success" data-action="click->document-note#save">Save</button>
                                        <button class="btn btn-sm btn-link" data-action="click->document-note#toggle">Cancel</button>
                                    </div>
                                </div>
                            </td>
                            <td>
                                {{ doc.createdAt|date('M d, Y') }}
                                <br />
                                {{ doc.createdAt|date('g:i a') }}
                            </td>
                            <td>Encrypted</td>
                            <td>
                                <button class="btn btn-sm btn-primary" type="button"
                                        data-action="click->document-viewer#decryptAndDownload"
                                        data-document-id="{{ doc.id.toString() }}"
                                        data-download-url="{{ path('internal_documents_payload', {'id': doc.id.toString()}) }}"
                                        data-metadata-url="{{ path('internal_documents_metadata', {'id': doc.id.toString()}) }}">
                                    Decrypt & Download
                                </button>

                                <button class="btn btn-sm btn-danger" type="button"
                                        data-controller="sweetalert"
                                        data-action="click->sweetalert#remove"
                                        data-sweetalert-title-value="Permanently delete document?"
                                        data-sweetalert-delete-url-value="{{ path('internal_documents_delete', {'id': doc.id.toString()}) }}">
                                    Permanently Delete
                                </button>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td>No documents uploaded for this client yet.</td>
                            <td colspan="2"></td>
                            <td>
                                <a href="{{ path('internal_requests_manage', { 'client_id': client.id }) }}" class="btn btn-sm btn-primary">
                                    Invite this client to upload documents
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% else %}
            <p>No client drop-boxes registered inside this tenant structure yet.</p>
        {% endfor %}
    </div>
{% endblock %}
