# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'
# Symfony does not load .env.local in the test env, so AWS_S3_BUCKET (defined
# there for dev) is unavailable. The S3 client is faked in functional tests, so
# any non-empty bucket name works here — no real AWS calls are made.
AWS_S3_BUCKET='test-bucket'
